# ─────────────────────────────────────────────
# AI Debug Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM API Keys ──────────────────────────────
# Used by config-loader when ai-debug.config.json contains "$VAR_NAME" syntax
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=

# ── REST API Server (api/) ────────────────────
# Port for the Hono REST API server
PORT=3100

# API key for authenticating REST clients (leave empty to disable auth in dev)
AI_DEBUG_API_KEY=

# ── Browser ───────────────────────────────────
# Set to "false" to show browser window during investigation
BROWSER_HEADLESS=true
