{
    "llm": {
        "default": {
            "provider": "openai",
            "model": "gpt-4o",
            "apiKey": "$OPENAI_API_KEY"
        }
    },
    "agent": {
        "mode": "autonomous",
        "maxIterations": 30,
        "maxRetries": 3
    },
    "browser": {
        "headless": true
    },
    "output": {
        "reportsDir": "./debug-reports",
        "streamLevel": "summary"
    }
}