{
    "llm": {
        "investigator": {
            "provider": "openai",
            "model": "gpt-4o",
            "apiKey": "$OPENAI_API_KEY"
        },
        "explorer": {
            "provider": "google",
            "model": "gemini-2.0-flash",
            "apiKey": "$GOOGLE_API_KEY"
        },
        "scout": {
            "provider": "google",
            "model": "gemini-2.0-flash",
            "apiKey": "$GOOGLE_API_KEY"
        }
    },
    "agent": {
        "mode": "autonomous",
        "maxIterations": 30,
        "maxRetries": 2,
        "callbackUrl": null
    },
    "browser": {
        "headless": true,
        "spaWaitMs": null,
        "guardrails": {
            "allowPayment": false,
            "allowDelete": false,
            "allowLogout": false
        }
    },
    "output": {
        "reportDir": "./debug-reports",
        "streamLevel": "summary"
    },
    "auth": {
        "strategy": null,
        "credentials": null
    }
}