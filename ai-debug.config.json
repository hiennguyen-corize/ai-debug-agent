{
    "llm": {
        "default": {
            "provider": "ollama-cloud",
            "model": "qwen3-coder",
            "baseURL": "https://ollama.com/v1",
            "apiKey": "$OLLAMA_API_KEY"
        },
        "investigator": {
            "provider": "ollama-cloud",
            "model": "qwen3-coder",
            "baseURL": "https://ollama.com/v1",
            "apiKey": "$OLLAMA_API_KEY"
        },
        "explorer": {
            "provider": "ollama-cloud",
            "model": "qwen3-coder",
            "baseURL": "https://ollama.com/v1",
            "apiKey": "$OLLAMA_API_KEY"
        },
        "scout": {
            "provider": "ollama-cloud",
            "model": "qwen3",
            "baseURL": "https://ollama.com/v1",
            "apiKey": "$OLLAMA_API_KEY"
        }
    },
    "agent": {
        "mode": "autonomous",
        "maxIterations": 60,
        "maxRetries": 2,
        "callbackUrl": null
    },
    "browser": {
        "headless": true,
        "spaWaitMs": null,
        "guardrails": {
            "allowPayment": false,
            "allowDelete": false,
            "allowLogout": false
        }
    },
    "output": {
        "reportDir": "./debug-reports",
        "streamLevel": "summary"
    },
    "auth": {
        "strategy": null,
        "credentials": null
    }
}
