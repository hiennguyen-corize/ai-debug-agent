{
    "llm": {
        "default": {
            "provider": "ollama-cloud",
            "model": "deepseek-v3.1:671b-cloud",
            "baseURL": "https://ollama.com/v1",
            "apiKey": "$OLLAMA_API_KEY"
        }
    },
    "agent": {
        "mode": "autonomous",
        "maxIterations": 50,
        "contextWindow": 160000,
        "maxRetries": 3
    },
    "browser": {
        "headless": true
    },
    "output": {
        "reportsDir": "./debug-reports",
        "streamLevel": "summary"
    }
}
