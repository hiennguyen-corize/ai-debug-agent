{
    "name": "@ai-debug/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/server.js",
    "imports": {
        "#routes/*.js": "./dist/routes/*.js",
        "#repositories/*.js": "./dist/repositories/*.js",
        "#middleware/*.js": "./dist/middleware/*.js",
        "#db/*.js": "./dist/db/*.js",
        "#services/*.js": "./dist/services/*.js",
        "#lib/*.js": "./dist/lib/*.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "dev": "node --watch dist/server.js"
    },
    "dependencies": {
        "@ai-debug/mcp-client": "workspace:*",
        "@ai-debug/shared": "workspace:*",
        "@hono/node-server": "^1.13.0",
        "better-sqlite3": "^11.0.0",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.7.0",
        "pino": "^9.14.0"
    }
}