{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "#routes/*.js": ["./routes/*.ts"],
      "#repositories/*.js": ["./repositories/*.ts"],
      "#middleware/*.js": ["./middleware/*.ts"],
      "#db/*.js": ["./db/*.ts"],
      "#services/*.js": ["./services/*.ts"],
      "#lib/*.js": ["./lib/*.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../shared" }, { "path": "../mcp-client" }]
}
