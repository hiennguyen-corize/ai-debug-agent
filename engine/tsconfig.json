{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "#agent/*.js": ["./src/agent/*.ts"],
      "#observability/*.js": ["./src/observability/*.ts"],
      "#reporter/*.js": ["./src/reporter/*.ts"],
      "#service/*.js": ["./src/service/*.ts"],
      "#sourcemap/*.js": ["./src/sourcemap/*.ts"],
      "#graph/*.js": ["./src/agent/graph/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../shared" }]
}
