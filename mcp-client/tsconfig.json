{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "#agent/*.js": ["./src/agent/*.ts"],
      "#observability/*.js": ["./src/observability/*.ts"],
      "#reporter/*.js": ["./src/reporter/*.ts"],
      "#service/*.js": ["./src/service/*.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "../shared" }]
}
