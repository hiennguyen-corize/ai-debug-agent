{
    "name": "@ai-debug/mcp-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "imports": {
        "#browser/*.js": "./dist/browser/*.js",
        "#constants.js": "./dist/constants.js",
        "#constants/*.js": "./dist/constants/*.js",
        "#sourcemap/*.js": "./dist/sourcemap/*.js",
        "#tools/*.js": "./dist/tools/*.js",
        "#types/*.js": "./dist/types/*.js",
        "#lib/*.js": "./dist/lib/*.js"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "dev": "node --watch dist/index.js"
    },
    "dependencies": {
        "@ai-debug/mcp-client": "workspace:*",
        "@ai-debug/shared": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.12.0",
        "pino": "^10.3.1",
        "playwright": "^1.50.0",
        "source-map": "^0.7.4",
        "zod": "^3.24.0"
    }
}