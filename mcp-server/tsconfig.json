{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "#browser/*.js": ["./src/browser/*.ts"],
      "#constants.js": ["./src/constants.ts"],
      "#constants/*.js": ["./src/constants/*.ts"],
      "#sourcemap/*.js": ["./src/sourcemap/*.ts"],
      "#tools/*.js": ["./src/tools/*.ts"],
      "#types/*.js": ["./src/types/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../shared" }, { "path": "../mcp-client" }]
}
