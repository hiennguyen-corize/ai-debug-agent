{
  "name": "ai-debug-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "shared",
    "engine",
    "api",
    "web"
  ],
  "scripts": {
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-all": "pnpm typecheck && pnpm lint && pnpm test",
    "dev:api": "pnpm --filter @ai-debug/api run dev",
    "dev": "tsc --build && pnpm --filter @ai-debug/api run dev",
    "start": "pnpm --filter @ai-debug/api run dev",
    "build": "tsc --build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
